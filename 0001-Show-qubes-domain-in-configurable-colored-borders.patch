+        label = QUBE_DARKPURPLE;
+    } else if (strcmp(qubelabel, "deepindigo") == 0) {
+        label = QUBE_DEEPINDIGO;
+    } else if (strcmp(qubelabel, "strongindigo") == 0) {
+        label = QUBE_STRONGINDIGO;
+    } else if (strcmp(qubelabel, "strongblue") == 0) {
+        label = QUBE_STRONGBLUE;
+    } else if (strcmp(qubelabel, "strongcyan") == 0) {
+        label = QUBE_STRONGCYAN;
+    } else if (strcmp(qubelabel, "strongteal") == 0) {
+        label = QUBE_STRONGTEAL;
+    } else if (strcmp(qubelabel, "stronggreen") == 0) {
+        label = QUBE_STRONGGREEN;
+    } else if (strcmp(qubelabel, "stronglime") == 0) {
+        label = QUBE_STRONGLIME;
+    } else if (strcmp(qubelabel, "strongyellow") == 0) {
+        label = QUBE_STRONGYELLOW;
+    } else if (strcmp(qubelabel, "strongorange") == 0) {
+        label = QUBE_STRONGORANGE;
+    } else {
+        valid_color = 0;
+    }
+
+    if (valid_color) {
+        APPLY_COLORS(focused_inactive, label);
+        APPLY_COLORS(focused, label);
+        APPLY_COLORS(unfocused, label);
+        APPLY_COLORS(urgent, label);
+    }
+
 
 #undef APPLY_COLORS
 }
